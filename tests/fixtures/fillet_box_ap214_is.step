GLOBAL_UNCERTAINTY_ASSIGNED_CONTEXT((#640)) GLOBAL_UNIT_ASSIGNED_CONTEXT
((#634,#638,#639)) REPRESENTATION_CONTEXT('Context #1',
  '3D Context with UNIT and UNCERTAINTY') );
#634 = ( CONVERSION_BASED_UNIT('INCH',#636) LENGTH_UNIT() NAMED_UNIT(
  #635) );
